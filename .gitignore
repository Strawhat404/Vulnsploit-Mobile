# ─── Dependencies ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ─── Expo / React Native ───────────────────────────────────────
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts
*.jks
*.p8
*.p12
*.key
*.pem
*.mobileprovision
*.orig.*
.metro-health-check*

# ─── Native build artifacts ────────────────────────────────────
# Regenerate with `npx expo prebuild` — do not commit generated native projects
ios/
android/
.kotlin/
local.properties
*.apk
*.aab
*.ipa
*.app
*.dSYM.zip
*.dSYM

# ─── Environment — never commit secrets ────────────────────────
.env
.env.*
!.env.example

# ─── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Testing / coverage ────────────────────────────────────────
coverage/
.nyc_output/
.jest/

# ─── Caches / temp ─────────────────────────────────────────────
.cache/
.turbo/
tmp/
temp/
*.tmp
*.temp

# ─── Editor / OS ───────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
*.sw?
*~

# Cursor IDE — keep shared project rules, ignore local IDE state
.cursor/*
!.cursor/rules/
!.cursor/rules/**

# ─── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo

# ─── WatermelonDB / SQLite (local dev DB) ──────────────────────
*.db
*.db-journal

# ─── EAS / Firebase / push credentials ───────────────────────
# Keep eas.json committed; never commit signing keys or service account files
.google-services.json
GoogleService-Info.plist
credentials.json
secrets.json
