# Copy to .env and adjust for your environment
# Expo only exposes variables prefixed with EXPO_PUBLIC_

# Django API base URL (no trailing slash)
# Local Docker backend maps host port 8001 → container 8000
EXPO_PUBLIC_API_URL=http://localhost:8001

# Optional: override API timeout in milliseconds (default 30000)
# EXPO_PUBLIC_API_TIMEOUT_MS=30000

# Optional: enable verbose API logging in dev
# EXPO_PUBLIC_DEBUG_API=true
